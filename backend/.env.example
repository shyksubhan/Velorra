# ============================================================
#  VELORRA BACKEND — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git — keep it private!
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3001

# ── JWT Secret (any long random string) ─────────────────────
JWT_SECRET=velorra_super_secret_jwt_key_change_this_in_production_2024

# ── Firebase Admin SDK ───────────────────────────────────────
# Get these from Firebase Console → Project Settings → Service Accounts
# → Generate new private key (downloads a JSON file)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour-private-key-here\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project.iam.gserviceaccount.com

# ── Email (Gmail SMTP) ───────────────────────────────────────
# Use a Gmail address + App Password (NOT your normal Gmail password)
# Enable 2FA on Gmail → Google Account → Security → App Passwords → Create one
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-character-app-password
EMAIL_TO=hello@velorra.com

# ── Admin Panel ──────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=velorra_admin_2024

# ── Frontend URL (for CORS) ──────────────────────────────────
FRONTEND_URL=http://localhost:3001
